QMainWindow { background: @background@; color: @text@; }
QDialog, QMessageBox { background: @surface@; color: @text@; }
QWidget { color: @text@; font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif; font-size: 9pt; }
QWidget#mainToolbarHost { background: @toolbarSurface@; border: none; border-bottom: 1px solid @toolbarBorder@; }
QToolBar#mainToolBar { background: transparent; border: none; spacing: 0px; }
QToolBar#mainToolBar::separator { width: 0px; margin: 0px; background: transparent; }
QToolButton, QPushButton { background: @control@; border: 1px solid @buttonBorder@; border-radius: 0px; padding: 4px 8px 4px 8px; color: @text@; }
QPushButton { min-width: 51px; }
QToolButton:hover, QPushButton:hover { background: @controlHover@; border-color: @buttonBorderHover@; }
QToolButton:pressed, QToolButton:checked, QPushButton:pressed { background: @accentPressed@; border-color: @focus@; }
QToolButton:disabled, QPushButton:disabled { background: @controlDisabled@; border-color: @disabledBorder@; color: @textSubtle@; }
QDialogButtonBox QPushButton, QMessageBox QPushButton, QFileDialog QPushButton { background: @control@; border: 1px solid @buttonBorder@; border-radius: 0px; padding: 4px 8px 4px 8px; color: @text@; }
QDialogButtonBox QPushButton:hover, QMessageBox QPushButton:hover, QFileDialog QPushButton:hover { background: @controlHover@; border-color: @buttonBorderHover@; }
QDialogButtonBox QPushButton:pressed, QMessageBox QPushButton:pressed, QFileDialog QPushButton:pressed { background: @accentPressed@; border-color: @focus@; }
QDialogButtonBox QPushButton:disabled, QMessageBox QPushButton:disabled, QFileDialog QPushButton:disabled { background: @dialogButtonDisabled@; border-color: @dialogButtonDisabledBorder@; color: @textSubtle@; }
QDialogButtonBox QPushButton:default, QMessageBox QPushButton:default, QFileDialog QPushButton:default { background: @accentSoft@; border: 1px solid @accent@; }
QDialogButtonBox QPushButton:default:hover, QMessageBox QPushButton:default:hover, QFileDialog QPushButton:default:hover { background: @accentHover@; border-color: @focus@; }
QDialogButtonBox QPushButton:default:pressed, QMessageBox QPushButton:default:pressed, QFileDialog QPushButton:default:pressed { background: @accentSoft@; border-color: @focus@; }
QDialogButtonBox QPushButton:focus, QMessageBox QPushButton:focus, QFileDialog QPushButton:focus { border: 1px solid @focus@; outline: none; }
QPushButton:default { background: @accentSoft@; border: 1px solid @accent@; }
QPushButton:default:hover { background: @accentHover@; border-color: @focus@; }
QPushButton:default:pressed { background: @accentSoft@; border-color: @focus@; }
QPushButton:focus { border: 1px solid @focus@; outline: none; }
QToolBar#mainToolBar QToolButton { border: none; margin: 0px; }
QToolBar#mainToolBar QToolButton:hover { background: @controlHover@; border-color: @buttonBorderHover@; }
QToolBar#mainToolBar QToolButton:pressed { background: @accentPressed@; border-color: @focus@; }
QToolBar#mainToolBar QToolButton:checked { border: none; }
QToolBar#mainToolBar QComboBox { padding: 2px 4px 2px 6px; }
QToolBar#mainToolBar QComboBox#routingModeCombo { background: @control@; border: 1px solid @buttonBorder@; padding: 2px 4px 2px 6px; }
QToolBar#mainToolBar QComboBox:hover { background: @controlHover@; border-color: @buttonBorderHover@; }
QToolBar#mainToolBar QToolButton#serverButton, QToolBar#mainToolBar QToolButton#subButton, QToolBar#mainToolBar QToolButton#settingButton, QToolBar#mainToolBar QToolButton#routingButton, QToolBar#mainToolBar QToolButton#updateButton, QToolBar#mainToolBar QToolButton#helpButton { background: @surface@; border: 1px solid @toolbarButtonBorder@; }
QToolBar#mainToolBar QToolButton#settingButton, QToolBar#mainToolBar QToolButton#subButton, QToolBar#mainToolBar QToolButton#routingButton, QToolBar#mainToolBar QToolButton#helpButton { border-color: transparent; }
QToolBar#mainToolBar QComboBox#routingModeCombo:hover { background: @controlHover@; border: 1px solid @buttonBorderHover@; }
QToolBar#mainToolBar QToolButton#serverButton:hover, QToolBar#mainToolBar QToolButton#subButton:hover, QToolBar#mainToolBar QToolButton#settingButton:hover, QToolBar#mainToolBar QToolButton#routingButton:hover, QToolBar#mainToolBar QToolButton#updateButton:hover, QToolBar#mainToolBar QToolButton#helpButton:hover { background: @controlHover@; border: 1px solid @buttonBorderHover@; }
QToolBar#mainToolBar QToolButton#serverButton:pressed, QToolBar#mainToolBar QToolButton#subButton:pressed, QToolBar#mainToolBar QToolButton#settingButton:pressed, QToolBar#mainToolBar QToolButton#routingButton:pressed, QToolBar#mainToolBar QToolButton#updateButton:pressed, QToolBar#mainToolBar QToolButton#helpButton:pressed { background: @accentPressed@; border: 1px solid @focus@; }
QToolBar#mainToolBar QToolButton[toolbarMenuButton="true"]::menu-indicator { image: none; }
QToolBar#mainToolBar QToolButton#proxyToggleButton, QToolBar#mainToolBar QToolButton#tunToggleButton { background: @control@; border: 1px solid @buttonBorder@; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:hover, QToolBar#mainToolBar QToolButton#tunToggleButton:hover { background: @controlHover@; border: 1px solid @buttonBorderHover@; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:pressed, QToolBar#mainToolBar QToolButton#tunToggleButton:pressed { background: @accentPressed@; border: 1px solid @focus@; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:checked, QToolBar#mainToolBar QToolButton#tunToggleButton:checked { background: @activeBackground@; color: @tabSelectedText@; border: 1px solid @accent@; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:checked:hover, QToolBar#mainToolBar QToolButton#tunToggleButton:checked:hover { border: 1px solid @focus@; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:disabled, QToolBar#mainToolBar QToolButton#tunToggleButton:disabled { color: @textSubtle@; border-color: @runtimeDisabledBorder@; }
QToolBar#mainToolBar QToolButton#qrCodeButton { background: @control@; border: 1px solid @buttonBorder@; }
QToolBar#mainToolBar QToolButton#qrCodeButton:hover { background: @controlHover@; border: 1px solid @buttonBorderHover@; }
QToolBar#mainToolBar QToolButton#qrCodeButton:pressed { background: @qrPressedBackground@; border: 1px solid @focus@; }
QToolBar#mainToolBar QToolButton#qrCodeButton:checked { background: @accentSoft@; border: 1px solid @accent@; }
QToolBar#mainToolBar QToolButton#qrCodeButton:checked:hover { background: @accentSoft@; border: 1px solid @focus@; }
QComboBox, QLineEdit, QSpinBox, QListView, QTableView, QTableWidget, QMenu, QTabWidget::pane { background: @surface@; border: 1px solid @border@; border-radius: 0px; }
QTextEdit { background: @surface@; border: 1px solid @border@; border-radius: 0px; }
QComboBox, QLineEdit, QSpinBox { padding: 2px 8px; }
QComboBox:hover, QLineEdit:hover, QSpinBox:hover, QListView:hover, QTextEdit:hover { border-color: @inputBorderHover@; }
QComboBox:focus, QLineEdit:focus, QSpinBox:focus, QListView:focus, QTextEdit:focus { border: 1px solid @focus@; }
QComboBox::drop-down { subcontrol-origin: padding; subcontrol-position: top right; width: 18px; border: none; border-left: 1px solid @border@; background: @surfaceMuted@; border-radius: 0px; }
QComboBox::drop-down:hover { background: @accentSoft@; }
QComboBox::down-arrow { image: url(@downArrowImage@); width: 10px; height: 10px; }
QComboBox[styledChevron="true"]::down-arrow { image: none; width: 0px; height: 0px; }
QComboBox QAbstractItemView::item { min-height: 30px; padding: 8px 10px; }
QToolBar#mainToolBar QComboBox QAbstractItemView::item { min-height: 24px; padding: 4px 8px; }
QSpinBox::up-button, QSpinBox::down-button { width: 18px; border: none; border-left: 1px solid @border@; background: @surfaceMuted@; border-radius: 0px; }
QSpinBox::up-button:hover, QSpinBox::down-button:hover { background: @accentSoft@; }
QSpinBox::up-arrow { image: url(@upArrowImage@); width: 10px; height: 10px; }
QSpinBox::down-arrow { image: url(@downArrowImage@); width: 10px; height: 10px; }
QAbstractItemView { selection-background-color: @selection@; selection-color: @selectionText@; outline: 0; }
QAbstractItemView#toolbarComboPopupView, QAbstractItemView#settingsComboPopupView { background: @surface@; color: @text@; border: 1px solid @border@; border-radius: 0px; padding: 4px; outline: 0; }
QAbstractItemView#toolbarComboPopupView::item { min-height: 24px; padding: 4px 8px; border-radius: 0px; }
QAbstractItemView#settingsComboPopupView::item { min-height: 24px; padding: 0px 8px; border-radius: 0px; }
QAbstractItemView#toolbarComboPopupView::item:hover, QAbstractItemView#settingsComboPopupView::item:hover { background: @hover@; color: @text@; }
QAbstractItemView#toolbarComboPopupView::item:selected, QAbstractItemView#settingsComboPopupView::item:selected { background: @selection@; color: @selectionText@; }
QHeaderView::section { background: @surfaceMuted@; color: @textMuted@; padding: 2px 8px; border: none; border-bottom: 1px solid @border@; border-right: 1px solid @borderMuted@; font-weight: 600; }
QHeaderView::section:last { border-right: none; }
QTableView[serverTableStyle="true"], QTableWidget[serverTableStyle="true"] { background: @surface@; alternate-background-color: @surfaceSubtle@; color: @text@; border: 1px solid @border@; font-size: 9pt; }
QTableView[serverTableStyle="true"] QHeaderView::section, QTableWidget[serverTableStyle="true"] QHeaderView::section { background: @surface@; }
QTableView#serverTableView[serverTableStyle="true"] { border: none; }
QSplitter#rootSplitter { background: @surface@; }
QWidget#settingsStackContainer { background: @surface@; border: none; }
QWidget#settingsTabBarContainer { background: transparent; border: none; border-bottom: 1px solid @panelBorder@; }
QWidget#subscriptionTabBarContainer { background: @surfaceMuted@; border: none; border-top: 1px solid @borderMuted@; border-bottom: 1px solid @border@; }
QWidget#settingsActionBar { background: @surface@; border: none; border-top: 1px solid @panelBorder@; }
QTabWidget#routingCustomRuleTabs::pane { background: @surface@; border: none; }
QTabWidget#coreDetailTabs::pane { background: @surface@; border: none; }
QTabBar#settingsTabBar, QTabBar#subscriptionTabBar, QTabWidget#routingCustomRuleTabs QTabBar { background: transparent; border: none; }
QTabBar#settingsTabBar::tab, QTabBar#subscriptionTabBar::tab { background: transparent; color: @textMuted@; font-weight: 600; padding: 6px 18px; margin: 0px 0px 1px 0px; border: none; outline: none; }
QTabBar#subscriptionTabBar::tab { background: @surface@; border: 1px solid @border@; padding: 5px 16px; margin: 0px 2px 0px 0px; }
QTabBar#settingsTabBar::tab:selected { background: @activeBackground@; color: @tabSelectedText@; }
QTabBar#subscriptionTabBar::tab:selected { background: @activeBackground@; border: 1px solid @accent@; color: @tabSelectedText@; }
QTabBar#settingsTabBar::tab:hover:!selected, QTabBar#subscriptionTabBar::tab:hover:!selected { background: @surfaceMuted@; color: @text@; }
QTabWidget#routingCustomRuleTabs QTabBar { background: transparent; border: 1px solid @border@; }
QWidget[routingCustomRulePage="true"] { background: @surface@; border: none; border-left: 1px solid @border@; border-right: 1px solid @border@; border-bottom: 1px solid @border@; }
QTabWidget#coreDetailTabs QTabBar { background: transparent; border: 1px solid @border@; }
QTabWidget#coreDetailTabs QWidget[coreDetailPage="true"] { background: @surface@; border: none; border-left: 1px solid @border@; border-right: 1px solid @border@; border-bottom: 1px solid @border@; }
QTabWidget#coreDetailTabs QTabBar::tab { background: transparent; color: @textMuted@; font-weight: 400; padding: 6px 18px 4px 18px; margin: 0px 0px 1px 0px; border: none; border-bottom: 2px solid transparent; outline: none; }
QTabWidget#coreDetailTabs QTabBar::tab:selected { color: @accent@; border-bottom: 2px solid @accent@; }
QTabWidget#coreDetailTabs QTabBar::tab:hover:!selected { color: @text@; border-bottom: 2px solid @inputBorderHover@; }
QTabWidget#routingCustomRuleTabs QTabBar::tab { background: transparent; color: @textMuted@; font-weight: 400; padding: 6px 18px 4px 18px; margin: 0px 0px 1px 0px; border: none; border-bottom: 2px solid transparent; outline: none; }
QTabWidget#routingCustomRuleTabs QTabBar::tab:selected { color: @accent@; border-bottom: 2px solid @accent@; }
QTabWidget#routingCustomRuleTabs QTabBar::tab:hover:!selected { color: @text@; border-bottom: 2px solid @inputBorderHover@; }
#serverHeaderRow { background: @surfaceMuted@; }
#serverHeaderRow { border-bottom: 1px solid @border@; }
QLineEdit#serverFilterEdit, QLineEdit#logFilterEdit { background: @surface@; border: 1px solid @border@; border-radius: 0px; padding: 2px 8px; }
QLineEdit#serverFilterEdit:hover, QLineEdit#logFilterEdit:hover { background: @surface@; border: 1px solid @inputBorderHover@; }
QLineEdit#serverFilterEdit:focus, QLineEdit#logFilterEdit:focus { background: @surface@; border: 1px solid @focus@; }
#logHeaderRow { background: @surfaceMuted@; border: none; border-bottom: 1px solid @border@; }
QWidget#loadingOverlay { background: @overlay@; border: none; }
QWidget#loadingContentWidget { background: @loadingContent@; border: 1px solid @border@; }
QLabel#loadingTitleLabel { color: @text@; font-weight: 700; font-size: 12pt; }
QWidget#loadingItemsWidget { background: transparent; border: none; }
QLabel#loadingChecklistItem { color: @neutral@; font-family: 'Segoe UI', 'Microsoft YaHei UI', 'Segoe UI Emoji', sans-serif; font-size: 10pt; }
QLabel#loadingChecklistDetail { color: @textSubtle@; font-family: 'Segoe UI', 'Microsoft YaHei UI', sans-serif; font-size: 9pt; }
QToolButton#logStickToBottomButton { background: transparent; border: 1px solid @subtleButtonBorder@; padding: 0px; }
QToolButton#logStickToBottomButton:hover { background: @hover@; border: 1px solid @accentHover@; }
QToolButton#logStickToBottomButton:pressed { background: @selection@; border: 1px solid @accentHover@; }
QToolButton#logStickToBottomButton:checked { background: @selection@; border: 1px solid @accentHover@; }
QToolButton#logStickToBottomButton:checked:hover { background: @selection@; border: 1px solid @accentHover@; }
#logPanel { background: transparent; border: none; border-bottom: 1px solid @border@; }
#qrPanel { background: @surface@; }
QWidget#shareContentPanel, QPlainTextEdit#shareLinkLabel { background: @surface@; }
QListView#logView { background: @surface@; border: none; border-radius: 0px; padding: 0px; }
QComboBox#uaCombo { border: none; background: transparent; padding: 0px 18px 0px 4px; }
QComboBox#uaCombo::drop-down { subcontrol-origin: padding; subcontrol-position: top right; border: none; background: transparent; width: 18px; }
QComboBox#uaCombo::drop-down:hover { background: transparent; }
QComboBox#uaCombo::down-arrow { image: url(@downArrowImage@); width: 10px; height: 10px; border: none; }
QLineEdit#uaComboLineEdit { border: none; background: transparent; padding: 0px; }
QLabel#logTitleLabel { color: @textMuted@; font-weight: 600; }
QLabel#aboutTitleLabel { font-size: 22px; font-weight: 700; }
QLabel#aboutRepoUrlValueLabel { color: @link@; }
QLabel#qrPlaceholder { border: none; background: @surface@; color: @textSubtle@; border-radius: 0px; }
QPlainTextEdit#shareLinkLabel { border: none; color: @textMuted@; padding: 0px; border-radius: 0px; }
QStatusBar { background: @surfaceMuted@; border: none; font-size: 9pt; }
QStatusBar QLabel { color: @textMuted@; padding: 0 4px; font-size: 9pt; }
QStatusBar QLabel#routingStatusLabel { color: @neutral@; font-weight: 400; }
QLabel#selectServerHintLabel { padding: 0 8px; }
QLabel[semanticState="success"] { color: @success@; font-weight: 600; }
QLabel[semanticState="warning"] { color: @warning@; font-weight: 600; }
QLabel[semanticState="error"] { color: @error@; font-weight: 600; }
QLabel[semanticState="neutral"] { color: @neutral@; font-weight: 600; }
QSplitter::handle { background: @surface@; }
QSplitter::handle:horizontal { width: 2px; margin: 0px; }
QSplitter::handle:vertical { height: 2px; margin: 0px; }
QSplitter#rootSplitter::handle { background: @splitter@; }
QSplitter#rootSplitter::handle:vertical { height: 1px; margin: 0px; }
QSplitter#topSplitter::handle { background: @splitter@; }
QSplitter#topSplitter::handle:hover { background: @splitterHover@; }
QSplitter#topSplitter::handle:horizontal { width: 3px; margin: 0px; }
QMenu { background: @surface@; color: @text@; border: 1px solid @border@; border-radius: 0px; padding: 4px; }
QMenu::item { padding: 4px 20px; border-radius: 0px; margin: 0px; }
QMenu::item:selected { background: @selection@; color: @selectionText@; }
QMenu::item:disabled { color: @textSubtle@; background: transparent; }
QMenu::separator { height: 1px; background: @menuSeparator@; margin: 4px 0px; }
QCheckBox { color: @textMuted@; }
QPushButton[baseRouteCard="true"] { text-align: left; padding: 8px; }
QScrollBar:vertical { background: transparent; width: 8px; margin: 6px 2px 6px 0; }
QScrollBar:horizontal { background: transparent; height: 8px; margin: 0 6px 2px 6px; }
QScrollBar::handle:vertical, QScrollBar::handle:horizontal { background: @scrollbar@; min-height: 24px; min-width: 24px; border-radius: 0px; }
QScrollBar::handle:vertical:hover, QScrollBar::handle:horizontal:hover { background: @scrollbarHover@; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical, QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical,
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal, QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal { background: transparent; width: 0px; height: 0px; }
QLineEdit[validationState="error"] { border: 1px solid @validationError@; }
