QMainWindow { background: #1a1f25; color: #e6eaf0; }
QDialog, QMessageBox { background: #20262d; color: #e6eaf0; }
QWidget { color: #e6eaf0; font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif; font-size: 9pt; }
QWidget#mainToolbarHost { background: #1a1f25; border: none; border-bottom: 1px solid #3a4550; }
QToolBar#mainToolBar { background: transparent; border: none; spacing: 0px; }
QToolBar#mainToolBar::separator { width: 0px; margin: 0px; background: transparent; }
QToolButton, QPushButton { background: #252d35; border: 1px solid #4c5967; border-radius: 0px; padding: 4px 8px 4px 8px; color: #e6eaf0; }
QPushButton { min-width: 51px; }
QToolButton:hover, QPushButton:hover { background: #2d3741; border-color: #7b8796; }
QToolButton:pressed, QToolButton:checked, QPushButton:pressed { background: #20372d; border-color: #77c58d; }
QToolButton:disabled, QPushButton:disabled { background: #252d35; border-color: #3a4550; color: #778392; }
