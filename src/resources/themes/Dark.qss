QDialogButtonBox QPushButton:default:pressed, QMessageBox QPushButton:default:pressed, QFileDialog QPushButton:default:pressed { background: #20372d; border-color: #77c58d; }
QDialogButtonBox QPushButton:focus, QMessageBox QPushButton:focus, QFileDialog QPushButton:focus { border: 1px solid #77c58d; outline: none; }
QPushButton:default { background: #20372d; border: 1px solid #58a07e; }
QPushButton:default:hover { background: #2d4c3f; border-color: #77c58d; }
QPushButton:default:pressed { background: #20372d; border-color: #77c58d; }
QPushButton:focus { border: 1px solid #77c58d; outline: none; }
