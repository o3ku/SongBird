QSpinBox::up-button:hover, QSpinBox::down-button:hover { background: #20372d; }
QSpinBox::up-arrow { image: url(:/app/up-dark.svg); width: 10px; height: 10px; }
QSpinBox::down-arrow { image: url(:/app/down-dark.svg); width: 10px; height: 10px; }
QAbstractItemView { selection-background-color: #20372d; selection-color: #e6eaf0; outline: 0; }
QAbstractItemView#toolbarComboPopupView, QAbstractItemView#settingsComboPopupView { background: #20262d; color: #e6eaf0; border: 1px solid #414b56; border-radius: 0px; padding: 4px; outline: 0; }
QAbstractItemView#toolbarComboPopupView::item { min-height: 24px; padding: 4px 8px; border-radius: 0px; }
QAbstractItemView#settingsComboPopupView::item { min-height: 24px; padding: 0px 8px; border-radius: 0px; }
QAbstractItemView#toolbarComboPopupView::item:hover, QAbstractItemView#settingsComboPopupView::item:hover { background: #202b25; color: #e6eaf0; }
QAbstractItemView#toolbarComboPopupView::item:selected, QAbstractItemView#settingsComboPopupView::item:selected { background: #20372d; color: #e6eaf0; }
QHeaderView::section { background: #252d35; color: #aab4c1; padding: 2px 8px; border: none; border-bottom: 1px solid #414b56; border-right: 1px solid #36404a; font-weight: 600; }
QHeaderView::section:last { border-right: none; }
QTableView[serverTableStyle="true"], QTableWidget[serverTableStyle="true"] { background: #20262d; alternate-background-color: #1d232a; color: #e6eaf0; border: 1px solid #414b56; font-size: 9pt; }
QTableView[serverTableStyle="true"] QHeaderView::section, QTableWidget[serverTableStyle="true"] QHeaderView::section { background: #20262d; }
QTableView#serverTableView[serverTableStyle="true"] { border: none; }
QSplitter#rootSplitter { background: #20262d; }
QWidget#settingsStackContainer { background: #20262d; border: none; }
QWidget#settingsTabBarContainer { background: transparent; border: none; border-bottom: 1px solid #323b45; }
QWidget#subscriptionTabBarContainer { background: #252d35; border: none; border-top: 1px solid #36404a; border-bottom: 1px solid #414b56; }
QWidget#settingsActionBar { background: #20262d; border: none; border-top: 1px solid #414b56; }
QTabWidget#routingCustomRuleTabs::pane { background: #20262d; border: none; }
QTabWidget#coreDetailTabs::pane { background: #20262d; border: none; }
QTabBar#settingsTabBar, QTabBar#subscriptionTabBar, QTabWidget#routingCustomRuleTabs QTabBar { background: transparent; border: none; }
QTabBar#settingsTabBar::tab, QTabBar#subscriptionTabBar::tab { background: transparent; color: #aab4c1; font-weight: 600; padding: 6px 18px; margin: 0px 0px 1px 0px; border: none; outline: none; }
QTabBar#subscriptionTabBar::tab { background: #20262d; border: 1px solid #414b56; padding: 5px 16px; margin: 0px 2px 0px 0px; }
QTabBar#settingsTabBar::tab:selected { background: #2d4c3f; color: #e6eaf0; }
QTabBar#subscriptionTabBar::tab:selected { background: #2d4c3f; border: 1px solid #58a07e; color: #e6eaf0; }
QTabBar#settingsTabBar::tab:hover:!selected, QTabBar#subscriptionTabBar::tab:hover:!selected { background: #252d35; color: #e6eaf0; }
