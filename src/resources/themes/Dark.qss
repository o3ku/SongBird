QTabWidget#coreDetailTabs QTabBar::tab:selected { color: #58a07e; border-bottom: 2px solid #58a07e; }
QTabWidget#coreDetailTabs QTabBar::tab:hover:!selected { color: #e6eaf0; border-bottom: 2px solid #697583; }
