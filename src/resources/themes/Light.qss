QLabel#loadingChecklistDetail { color: #8a94a6; font-family: 'Segoe UI', 'Microsoft YaHei UI', sans-serif; font-size: 9pt; }
QToolButton#logStickToBottomButton { background: transparent; border: 1px solid #d0d5dd; padding: 0px; }
QToolButton#logStickToBottomButton:hover { background: #f2f6f3; border: 1px solid #d8e8df; }
