QLineEdit#serverFilterEdit:hover, QLineEdit#logFilterEdit:hover { background: #ffffff; border: 1px solid #98a2b3; }
QLineEdit#serverFilterEdit:focus, QLineEdit#logFilterEdit:focus { background: #ffffff; border: 1px solid #98a2b3; }
#logHeaderRow { background: #f2f4f7; border: none; border-bottom: 1px solid #d0d5dd; }
QWidget#loadingOverlay { background: rgba(255, 255, 255, 224); border: none; }
QWidget#loadingContentWidget { background: rgba(255, 255, 255, 192); border: 1px solid #d0d5dd; }
QLabel#loadingTitleLabel { color: #1f2328; font-weight: 700; font-size: 12pt; }
QWidget#loadingItemsWidget { background: transparent; border: none; }
