QToolButton#logStickToBottomButton:checked { background: #e6f0eb; border: 1px solid #d8e8df; }
QToolButton#logStickToBottomButton:checked:hover { background: #e6f0eb; border: 1px solid #d8e8df; }
#logPanel { background: transparent; border: none; border-bottom: 1px solid #d0d5dd; }
#qrPanel { background: #ffffff; }
QWidget#shareContentPanel, QPlainTextEdit#shareLinkLabel { background: #ffffff; }
QListView#logView { background: #ffffff; border: none; border-radius: 0px; padding: 0px; }
