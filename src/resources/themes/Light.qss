QMainWindow { background: #f7f8fa; color: #1f2328; }
QDialog, QMessageBox { background: #ffffff; color: #1f2328; }
QWidget { color: #1f2328; font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif; font-size: 9pt; }
QWidget#mainToolbarHost { background: #ffffff; border: none; border-bottom: 1px solid #98a2b3; }
QToolBar#mainToolBar { background: transparent; border: none; spacing: 0px; }
QToolBar#mainToolBar::separator { width: 0px; margin: 0px; background: transparent; }
QToolButton, QPushButton { background: #ffffff; border: 1px solid #d0d5dd; border-radius: 0px; padding: 4px 8px 4px 8px; color: #1f2328; }
QPushButton { min-width: 51px; }
QToolButton:hover, QPushButton:hover { background: #f2f4f7; border-color: #98a2b3; }
QToolButton:pressed, QToolButton:checked, QPushButton:pressed { background: #e6f0eb; border-color: #346f59; }
QToolButton:disabled, QPushButton:disabled { background: #f2f4f7; border-color: #e4e7ec; color: #8a94a6; }
QDialogButtonBox QPushButton, QMessageBox QPushButton, QFileDialog QPushButton { background: #ffffff; border: 1px solid #d0d5dd; border-radius: 0px; padding: 4px 8px 4px 8px; color: #1f2328; }
QDialogButtonBox QPushButton:hover, QMessageBox QPushButton:hover, QFileDialog QPushButton:hover { background: #f2f4f7; border-color: #98a2b3; }
QDialogButtonBox QPushButton:pressed, QMessageBox QPushButton:pressed, QFileDialog QPushButton:pressed { background: #e6f0eb; border-color: #346f59; }
QDialogButtonBox QPushButton:disabled, QMessageBox QPushButton:disabled, QFileDialog QPushButton:disabled { background: #f2f4f7; border-color: #e4e7ec; color: #8a94a6; }
QDialogButtonBox QPushButton:default, QMessageBox QPushButton:default, QFileDialog QPushButton:default { background: #ffffff; border: 1px solid #d0d5dd; }
QDialogButtonBox QPushButton:default:hover, QMessageBox QPushButton:default:hover, QFileDialog QPushButton:default:hover { background: #f2f4f7; border-color: #98a2b3; }
QDialogButtonBox QPushButton:default:pressed, QMessageBox QPushButton:default:pressed, QFileDialog QPushButton:default:pressed { background: #e6f0eb; border-color: #346f59; }
QDialogButtonBox QPushButton:focus, QMessageBox QPushButton:focus, QFileDialog QPushButton:focus { border: 1px solid #98a2b3; outline: none; }
QPushButton:default { background: #ffffff; border: 1px solid #d0d5dd; }
QPushButton:default:hover { background: #f2f4f7; border-color: #98a2b3; }
QPushButton:default:pressed { background: #e6f0eb; border-color: #346f59; }
QPushButton:focus { border: 1px solid #98a2b3; outline: none; }
QToolBar#mainToolBar QToolButton { border: none; margin: 0px; }
QToolBar#mainToolBar QToolButton:hover { background: #ffffff; border-color: #98a2b3; }
QToolBar#mainToolBar QToolButton:pressed { background: #ffffff; border-color: #98a2b3; }
QToolBar#mainToolBar QToolButton:checked { border: none; }
QToolBar#mainToolBar QComboBox { padding: 2px 4px 2px 6px; }
QToolBar#mainToolBar QComboBox#routingModeCombo { border: 1px solid #d0d5dd; padding: 2px 4px 2px 6px; }
QToolBar#mainToolBar QComboBox:hover { background: #ffffff; border-color: #98a2b3; }
QToolBar#mainToolBar QToolButton#serverButton, QToolBar#mainToolBar QToolButton#subButton, QToolBar#mainToolBar QToolButton#settingButton, QToolBar#mainToolBar QToolButton#routingButton, QToolBar#mainToolBar QToolButton#updateButton, QToolBar#mainToolBar QToolButton#helpButton { border: 1px solid #ffffff; }
QToolBar#mainToolBar QComboBox#routingModeCombo:hover { background: #ffffff; border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#serverButton:hover, QToolBar#mainToolBar QToolButton#subButton:hover, QToolBar#mainToolBar QToolButton#settingButton:hover, QToolBar#mainToolBar QToolButton#routingButton:hover, QToolBar#mainToolBar QToolButton#updateButton:hover, QToolBar#mainToolBar QToolButton#helpButton:hover { background: #ffffff; border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#serverButton:pressed, QToolBar#mainToolBar QToolButton#subButton:pressed, QToolBar#mainToolBar QToolButton#settingButton:pressed, QToolBar#mainToolBar QToolButton#routingButton:pressed, QToolBar#mainToolBar QToolButton#updateButton:pressed, QToolBar#mainToolBar QToolButton#helpButton:pressed { border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton[toolbarMenuButton="true"]::menu-indicator { image: none; }
QToolBar#mainToolBar QToolButton#proxyToggleButton, QToolBar#mainToolBar QToolButton#tunToggleButton { border: 1px solid #d0d5dd; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:hover, QToolBar#mainToolBar QToolButton#tunToggleButton:hover { background: #ffffff; border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:pressed, QToolBar#mainToolBar QToolButton#tunToggleButton:pressed { border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:checked, QToolBar#mainToolBar QToolButton#tunToggleButton:checked { background: #346f59; color: #ffffff; border: 1px solid #346f59; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:checked:hover, QToolBar#mainToolBar QToolButton#tunToggleButton:checked:hover { border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#proxyToggleButton:disabled, QToolBar#mainToolBar QToolButton#tunToggleButton:disabled { color: #8a94a6; border-color: #d0d5dd; }
QToolBar#mainToolBar QToolButton#qrCodeButton { border: 1px solid #d0d5dd; }
QToolBar#mainToolBar QToolButton#qrCodeButton:hover { border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#qrCodeButton:pressed { border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#qrCodeButton:checked { background: transparent; border: 1px solid #98a2b3; }
QToolBar#mainToolBar QToolButton#qrCodeButton:checked:hover { background: transparent; border: 1px solid #98a2b3; }
QComboBox, QLineEdit, QSpinBox, QListView, QTableView, QTableWidget, QMenu, QTabWidget::pane { background: #ffffff; border: 1px solid #d0d5dd; border-radius: 0px; }
QTextEdit { background: #ffffff; border: 1px solid #d0d5dd; border-radius: 0px; }
QComboBox, QLineEdit, QSpinBox { padding: 2px 8px; }
QComboBox:hover, QLineEdit:hover, QSpinBox:hover, QListView:hover, QTextEdit:hover { border-color: #98a2b3; }
QComboBox:focus, QLineEdit:focus, QSpinBox:focus, QListView:focus, QTextEdit:focus { border: 1px solid #98a2b3; }
QComboBox::drop-down { subcontrol-origin: padding; subcontrol-position: top right; width: 18px; border: none; border-left: 1px solid #d0d5dd; background: #f2f4f7; border-radius: 0px; }
QComboBox::drop-down:hover { background: #e6f0eb; }
QComboBox::down-arrow { image: url(:/app/down.svg); width: 10px; height: 10px; }
QComboBox[styledChevron="true"]::down-arrow { image: none; width: 0px; height: 0px; }
QComboBox QAbstractItemView::item { min-height: 30px; padding: 8px 10px; }
QToolBar#mainToolBar QComboBox QAbstractItemView::item { min-height: 24px; padding: 4px 8px; }
QSpinBox::up-button, QSpinBox::down-button { width: 18px; border: none; border-left: 1px solid #d0d5dd; background: #f2f4f7; border-radius: 0px; }
QSpinBox::up-button:hover, QSpinBox::down-button:hover { background: #e6f0eb; }
QSpinBox::up-arrow { image: url(:/app/up.svg); width: 10px; height: 10px; }
QSpinBox::down-arrow { image: url(:/app/down.svg); width: 10px; height: 10px; }
QAbstractItemView { selection-background-color: #e6f0eb; selection-color: #1f2328; outline: 0; }
QAbstractItemView#toolbarComboPopupView, QAbstractItemView#settingsComboPopupView { background: #ffffff; color: #1f2328; border: 1px solid #d0d5dd; border-radius: 0px; padding: 4px; outline: 0; }
QAbstractItemView#toolbarComboPopupView::item { min-height: 24px; padding: 4px 8px; border-radius: 0px; }
QAbstractItemView#settingsComboPopupView::item { min-height: 24px; padding: 0px 8px; border-radius: 0px; }
QAbstractItemView#toolbarComboPopupView::item:hover, QAbstractItemView#settingsComboPopupView::item:hover { background: #f2f6f3; color: #1f2328; }
QAbstractItemView#toolbarComboPopupView::item:selected, QAbstractItemView#settingsComboPopupView::item:selected { background: #e6f0eb; color: #1f2328; }
QHeaderView::section { background: #f2f4f7; color: #667085; padding: 2px 8px; border: none; border-bottom: 1px solid #d0d5dd; border-right: 1px solid #e4e7ec; font-weight: 600; }
QHeaderView::section:last { border-right: none; }
QTableView[serverTableStyle="true"], QTableWidget[serverTableStyle="true"] { background: #ffffff; alternate-background-color: #f9fafb; color: #1f2328; border: 1px solid #d0d5dd; font-size: 9pt; }
QTableView[serverTableStyle="true"] QHeaderView::section, QTableWidget[serverTableStyle="true"] QHeaderView::section { background: #ffffff; }
QTableView#serverTableView[serverTableStyle="true"] { border: none; }
QSplitter#rootSplitter { background: #ffffff; }
QWidget#settingsStackContainer { background: #ffffff; border: none; }
QWidget#settingsTabBarContainer { background: transparent; border: none; border-bottom: 1px solid #98a2b3; }
QWidget#subscriptionTabBarContainer { background: #f2f4f7; border: none; border-top: 1px solid #e4e7ec; border-bottom: 1px solid #d0d5dd; }
QWidget#settingsActionBar { background: #ffffff; border: none; border-top: 1px solid #98a2b3; }
QTabWidget#routingCustomRuleTabs::pane { background: #ffffff; border: none; }
QTabWidget#coreDetailTabs::pane { background: #ffffff; border: none; }
QTabBar#settingsTabBar, QTabBar#subscriptionTabBar, QTabWidget#routingCustomRuleTabs QTabBar { background: transparent; border: none; }
QTabBar#settingsTabBar::tab, QTabBar#subscriptionTabBar::tab { background: transparent; color: #667085; font-weight: 600; padding: 6px 18px; margin: 0px 0px 1px 0px; border: none; outline: none; }
QTabBar#subscriptionTabBar::tab { background: #ffffff; border: 1px solid #d0d5dd; padding: 5px 16px; margin: 0px 2px 0px 0px; }
QTabBar#settingsTabBar::tab:selected { background: #346f59; color: #ffffff; }
QTabBar#subscriptionTabBar::tab:selected { background: #346f59; border: 1px solid #346f59; color: #ffffff; }
QTabBar#settingsTabBar::tab:hover:!selected, QTabBar#subscriptionTabBar::tab:hover:!selected { background: #f2f4f7; color: #1f2328; }
QTabWidget#routingCustomRuleTabs QTabBar { background: transparent; border: 1px solid #d0d5dd; }
QWidget[routingCustomRulePage="true"] { background: #ffffff; border: none; border-left: 1px solid #d0d5dd; border-right: 1px solid #d0d5dd; border-bottom: 1px solid #d0d5dd; }
QTabWidget#coreDetailTabs QTabBar { background: transparent; border: 1px solid #d0d5dd; }
QTabWidget#coreDetailTabs QWidget[coreDetailPage="true"] { background: #ffffff; border: none; border-left: 1px solid #d0d5dd; border-right: 1px solid #d0d5dd; border-bottom: 1px solid #d0d5dd; }
QTabWidget#coreDetailTabs QTabBar::tab { background: transparent; color: #667085; font-weight: 400; padding: 6px 18px 4px 18px; margin: 0px 0px 1px 0px; border: none; border-bottom: 2px solid transparent; outline: none; }
QTabWidget#coreDetailTabs QTabBar::tab:selected { color: #346f59; border-bottom: 2px solid #346f59; }
QTabWidget#coreDetailTabs QTabBar::tab:hover:!selected { color: #1f2328; border-bottom: 2px solid #98a2b3; }
QTabWidget#routingCustomRuleTabs QTabBar::tab { background: transparent; color: #667085; font-weight: 400; padding: 6px 18px 4px 18px; margin: 0px 0px 1px 0px; border: none; border-bottom: 2px solid transparent; outline: none; }
QTabWidget#routingCustomRuleTabs QTabBar::tab:selected { color: #346f59; border-bottom: 2px solid #346f59; }
QTabWidget#routingCustomRuleTabs QTabBar::tab:hover:!selected { color: #1f2328; border-bottom: 2px solid #98a2b3; }
#serverHeaderRow { background: #f2f4f7; }
#serverHeaderRow { border-bottom: 1px solid #d0d5dd; }
