QLineEdit#uaComboLineEdit { border: none; background: transparent; padding: 0px; }
QLabel#logTitleLabel { color: #667085; font-weight: 600; }
QLabel#aboutTitleLabel { font-size: 22px; font-weight: 700; }
QLabel#aboutRepoUrlValueLabel { color: #0969da; }
QLabel#qrPlaceholder { border: none; background: #ffffff; color: #8a94a6; border-radius: 0px; }
QPlainTextEdit#shareLinkLabel { border: none; color: #667085; padding: 0px; border-radius: 0px; }
QStatusBar { background: #f2f4f7; border: none; font-size: 9pt; }
QStatusBar QLabel { color: #667085; padding: 0 4px; font-size: 9pt; }
QStatusBar QLabel#routingStatusLabel { color: #4d5f73; font-weight: 400; }
QLabel[semanticState="#2f6d45"] { color: #2f6d45; font-weight: 600; }
QLabel[semanticState="#8a6a20"] { color: #8a6a20; font-weight: 600; }
QLabel[semanticState="#a33a3a"] { color: #a33a3a; font-weight: 600; }
QLabel[semanticState="#4d5f73"] { color: #4d5f73; font-weight: 600; }
QSplitter::handle { background: #ffffff; }
QSplitter::handle:horizontal { width: 2px; margin: 0px; }
QSplitter::handle:vertical { height: 2px; margin: 0px; }
QSplitter#rootSplitter::handle { background: #98a2b3; }
QSplitter#rootSplitter::handle:vertical { height: 1px; margin: 0px; }
QSplitter#topSplitter::handle { background: #d0d5dd; }
QSplitter#topSplitter::handle:hover { background: #98a2b3; }
QSplitter#topSplitter::handle:horizontal { width: 3px; margin: 0px; }
QMenu { background: #ffffff; color: #1f2328; border: 1px solid #d0d5dd; border-radius: 0px; padding: 4px; }
QMenu::item { padding: 4px 20px; border-radius: 0px; margin: 0px; }
QMenu::item:selected { background: #e6f0eb; color: #1f2328; }
QMenu::item:disabled { color: #8a94a6; background: transparent; }
QMenu::separator { height: 1px; background: #e4e7ec; margin: 4px 0px; }
QCheckBox { color: #667085; }
QPushButton[baseRouteCard="true"] { text-align: left; padding: 8px; }
QScrollBar:vertical { background: transparent; width: 8px; margin: 6px 2px 6px 0; }
QScrollBar:horizontal { background: transparent; height: 8px; margin: 0 6px 2px 6px; }
QScrollBar::handle:vertical, QScrollBar::handle:horizontal { background: #98a2b3; min-height: 24px; min-width: 24px; border-radius: 0px; }
QScrollBar::handle:vertical:hover, QScrollBar::handle:horizontal:hover { background: #667085; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical, QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical,
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal, QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal { background: transparent; width: 0px; height: 0px; }
QLineEdit[validationState="error"] { border: 1px solid #a33a3a; }
